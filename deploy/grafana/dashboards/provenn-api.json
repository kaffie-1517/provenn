      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(provenn_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{ route }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Invoices Issued (total)",
